// 2. Poll (議題) テーブル
// 投票対象者(targetRole)と決定条件(threshold)を定義する

enum PollTarget {
  MEMBER // 構成員全員（仮入会除く）
  ADMIN // 役員会のみ
}

enum PollThreshold {
  MAJORITY // 過半数
  TWO_THIRDS // 3分の2
}

// 準備中(DRAFT)ステータスを追加

enum PollStatus {
  DRAFT // 準備中
  VOTING // 投票中
  CLOSED // 終了
}

// ★ 投票モード (記名投票のみ)

enum PollVoteType {
  OPEN // 記名投票
}

model Poll {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  title       String // 議題名
  description String? // 概要
  status      PollStatus    @default(DRAFT) // "DRAFT", "VOTING", "CLOSED"
  targetRole  PollTarget // 投票対象者 (MEMBER or ADMIN)
  threshold   PollThreshold // 決定条件 (MAJORITY or TWO_THIRDS)
  voteType    PollVoteType  @default(OPEN) // 投票モード (記名投票)
  result      String? // 結果 ("PASSED", "FAILED")
  startDate   DateTime? // 投票開始日時
  endDate     DateTime? // 投票終了日時
  createdBy   String? // 作成者のユーザーID
  deletedAt   DateTime? // ソフトデリート用
  version     Int           @default(0) // 楽観的ロック用
  closedAt    DateTime? // 投票終了した日時

  // この議題の「記名投票」の記録
  openVotes OpenVote[]

  @@index([status, targetRole])
  @@index([createdAt, status])
  @@index([deletedAt])
}

// 選択肢（共通）

enum VoteChoice {
  AGREE // 賛成
  DISAGREE // 反対
  ABSTAIN // 無効票 (白票・棄権)
}

// ★ 3. OpenVote (記名投票) テーブル
// 「誰が」「どの議題に」「何に」投票したかを記録する

model OpenVote {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now()) // 投票日時
  userId    String
  pollId    String
  choice    VoteChoice // 賛成, 反対, 無効票
  voterRole UserRole // 投票時の役割（後から変更されても整合性を保つ）
  voterName String // 投票時の名前（変更されても記録を保持）

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  // 同じユーザーが同じ議題に複数回投票できないようにする
  @@unique([userId, pollId])
  @@index([pollId, choice])
  @@index([createdAt])
}
