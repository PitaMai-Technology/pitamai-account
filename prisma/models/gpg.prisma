model UserGpgKey {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Armored 公開鍵（メール署名検証・暗号化に利用）
  publicKey           String
  /// AES-256-GCM で暗号化された秘密鍵
  encryptedPrivateKey String
  encryptionIv        String
  encryptionAuthTag   String
  /// 鍵のフィンガープリント（40文字の大文字16進数）
  fingerprint         String
  /// 鍵に紐付いたメールアドレス
  email               String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId])
  @@index([userId])
  @@map("user_gpg_key")
}
