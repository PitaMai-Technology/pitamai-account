{
  "name": "pitamai-only",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm exec prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "generate:better-auth": "pnpm dlx @better-auth/cli generate --config server/utils/auth.ts",
    "migration:better-auth": "pnpm dlx @better-auth/cli migrate --config server/utils/auth.ts",
    "generate:prisma": "pnpm exec prisma generate --schema ./prisma",
    "migration:prisma": "pnpm exec prisma migrate dev --schema ./prisma",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/ui": "^4.4.0",
    "@nuxtjs/mdc": "0.19.2",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/client": "^6.19.2",
    "@sentry/nuxt": "^10.39.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@types/nodemailer": "^7.0.11",
    "@vue-dnd-kit/core": "1.7.0",
    "@vueuse/core": "^14.2.1",
    "better-auth": "^1.5.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.39.3",
    "imapflow": "^1.2.10",
    "import-in-the-middle": "^2.0.6",
    "isomorphic-dompurify": "^2.36.0",
    "mailparser": "^3.9.3",
    "nodemailer": "^7.0.13",
    "nuxt": "^4.3.1",
    "openpgp": "^6.3.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/icon": "^2.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.10.13",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4",
      "vite": "npm:rolldown-vite@latest"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "prisma"
    ]
  }
}
