{
  "name": "pitamai-only",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm exec prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "generate:better-auth": "pnpx @better-auth/cli generate --config server/utils/auth.ts",
    "migration:better-auth": "pnpx @better-auth/cli migrate --config server/utils/auth.ts",
    "migration:prisma": "pnpm exec prisma migrate dev --schema ./prisma",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@nuxt/eslint": "^1.11.0",
    "@nuxt/ui": "^4.2.1",
    "@prisma/client": "^6.19.0",
    "argon2": "^0.44.0",
    "better-auth": "^1.4.4",
    "better-sqlite3": "^12.4.6",
    "eslint": "^9.39.1",
    "nodemailer": "^7.0.11",
    "nuxt": "^4.2.1",
    "pino": "^10.1.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.1",
    "prisma": "^6.19.0"
  },
  "prisma": {
    "schema": "./prisma"
  }
}
