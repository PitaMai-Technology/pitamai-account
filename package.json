{
  "name": "pitamai-only",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm exec prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "generate:better-auth": "pnpx @better-auth/cli generate --config server/utils/auth.ts",
    "migration:better-auth": "pnpx @better-auth/cli migrate --config server/utils/auth.ts",
    "generate:prisma": "pnpm exec prisma generate --schema ./prisma",
    "migration:prisma": "pnpm exec prisma migrate dev --schema ./prisma",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/ui": "^4.2.1",
    "@prisma/client": "^6.19.1",
    "@sentry/nuxt": "^10.30.0",
    "@sentry/vite-plugin": "^4.6.1",
    "better-auth": "^1.4.6",
    "better-sqlite3": "^12.5.0",
    "eslint": "^9.39.1",
    "import-in-the-middle": "^2.0.0",
    "nodemailer": "^7.0.11",
    "nuxt": "^4.2.2",
    "pino": "^10.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.3",
    "@types/nodemailer": "^7.0.4",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "prisma": "^6.19.1"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4",
      "vite": "npm:rolldown-vite@latest"
    }
  }
}
