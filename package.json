{
  "name": "pitamai-only",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm exec prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "generate:better-auth": "pnpm dlx @better-auth/cli generate --config server/utils/auth.ts",
    "migration:better-auth": "pnpm dlx @better-auth/cli migrate --config server/utils/auth.ts",
    "generate:prisma": "pnpm exec prisma generate --schema ./prisma",
    "migration:prisma": "pnpm exec prisma migrate dev --schema ./prisma",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.10",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/mdc": "0.19.2",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/client": "^6.19.3",
    "@sentry/nuxt": "^10.52.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@vueuse/core": "^14.3.0",
    "better-auth": "^1.6.10",
    "eslint": "^9.39.4",
    "import-in-the-middle": "^2.0.6",
    "nuxt": "^4.4.5",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "resend": "^6.12.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.2",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/icon": "^2.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.12.3",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4",
      "vite": "^7.3.2",
      "nitropack": "^2.13.4",
      "h3": "^1.15.9",
      "kysely": "^0.28.17",
      "postcss": "^8.5.10",
      "yaml": "^2.8.3",
      "tar": "^7.5.11",
      "serialize-javascript": "^7.0.5",
      "picomatch": "^4.0.4",
      "defu": "^6.1.5",
      "drizzle-orm": "^0.45.2",
      "effect": "^3.20.0",
      "flatted": "^3.4.2",
      "brace-expansion": "^5.0.5",
      "minimatch": "^9.0.7"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@sentry/cli"
    ]
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "version": "0.1.0-alpha.4"
}
